# =====================================================
# AgriFlow .env.example
# Copy to .env.local (web) and .env (pipeline/crew). Never commit real values.
# =====================================================

# ---- Supabase (EU region: eu-central-1 / Frankfurt) ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...public-anon-key...
SUPABASE_SERVICE_KEY=eyJhbGciOi...service-role-key...DO-NOT-EXPOSE

# ---- App ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=AgriFlow
NEXT_PUBLIC_DEFAULT_LOCALE=en
NEXT_PUBLIC_SUPPORTED_LOCALES=en,es,it,de

# ---- LLM providers ----
OPENAI_API_KEY=sk-...                  # ONLY for embeddings (no PII sent)
GROQ_API_KEY=gsk_...                   # Cheap reasoning (Llama 3.3 70B)
MISTRAL_API_KEY=...                    # EU-hosted, used when PII may be present

# ---- Rate limiting (Upstash Redis) ----
UPSTASH_REDIS_REST_URL=https://eu1-...upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# ---- Email (Resend, EU region) ----
RESEND_API_KEY=re_...
RESEND_FROM=hello@agriflow.eu

# ---- Twilio (WhatsApp / SMS OTP) ----
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_VERIFY_SID=VA...

# ---- Modal (Python crew + ingestion) ----
MODAL_TOKEN_ID=ak-...
MODAL_TOKEN_SECRET=as-...

# ---- Sentry / Axiom (observability) ----
SENTRY_DSN=https://...@o0.ingest.sentry.io/0
NEXT_PUBLIC_SENTRY_DSN=https://...@o0.ingest.sentry.io/0
AXIOM_TOKEN=xaat-...
AXIOM_DATASET=agriflow

# ---- PostHog (EU host) ----
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com

# ---- Scraping politeness ----
AGRIFLOW_BOT_CONTACT=bot@agriflow.eu
AGRIFLOW_RATE_LIMIT_RPS=1

# ---- Compliance flags ----
ENABLE_AI_TRANSLATION_NOTICES=true
DISABLE_FORBIDDEN_PHRASES_CHECK=false
