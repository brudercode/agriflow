# =====================================================
# AgriFlow .gitignore
# =====================================================

# ---- Node / Next.js ----
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz
.next/
out/
build/
dist/
.vercel
*.tsbuildinfo
next-env.d.ts

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
*.egg-info/
.uv/
uv.lock

# ---- Environment ----
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
!.env.example

# ---- Supabase ----
supabase/.branches
supabase/.temp
supabase/.env

# ---- Editors ----
.vscode/
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ---- Logs ----
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# ---- OS ----
*.tmp
*.bak

# ---- Sentry / monitoring ----
.sentryclirc

# ---- Local data dumps ----
data/raw/
data/cache/
*.parquet
*.duckdb
